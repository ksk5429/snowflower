# Copy to .env and fill in. Never commit .env.

# ---- YouTube Data API v3 ----
# Get from https://console.cloud.google.com -> APIs & Services -> Credentials
# Create OAuth 2.0 Client ID (Desktop app), download JSON, save next to this file
YOUTUBE_CLIENT_SECRET_PATH=youtube_client_secret.json
YOUTUBE_TOKEN_PATH=youtube_token.json
YOUTUBE_CHANNEL_ID=

# ---- LinkedIn Posts API ----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8765/callback
LINKEDIN_TOKEN_PATH=linkedin_token.json
LINKEDIN_AUTHOR_URN=

# ---- Bluesky ----
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ---- X (Twitter) API v2 (pay-per-use, post-Feb 2026) ----
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ---- Threads API ----
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ---- TikTok Content Posting API (post-audit) ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ---- Instagram Graph API (post-App-Review) ----
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# ---- Reddit (read-only metrics; posting is manual) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=snowflower-metrics/0.1
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ---- Naver Blog ----
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_ACCESS_TOKEN=

# ---- Beehiiv (US/global newsletter — primary owned-audience platform) ----
# https://app.beehiiv.com -> Settings -> Integrations -> API
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ---- Stibee (KR newsletter) ----
STIBEE_API_KEY=
STIBEE_LIST_ID=

# ---- Optional GenAI ----
ELEVENLABS_API_KEY=
FAL_KEY=
